{
  "name": "mavdeck",
  "private": false,
  "version": "0.1.0",
  "description": "A fast, web-based MAVLink telemetry viewer. No install, no MAVLink dependencies — just load your dialect XML and start plotting.",
  "author": "Dan Wilson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DanWilson00/MavDeck.git"
  },
  "homepage": "https://mavdeck.netlify.app",
  "bugs": {
    "url": "https://github.com/DanWilson00/MavDeck/issues"
  },
  "keywords": ["mavlink", "telemetry", "visualization", "pwa", "solidjs", "uplot", "drone"],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run build && npm run test"
  },
  "dependencies": {
    "gridstack": "^12.4.2",
    "idb-keyval": "^6.2.2",
    "leaflet": "^1.9.4",
    "solid-js": "^1.9.11",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/leaflet": "^1.9.21",
    "@types/w3c-web-serial": "^1.0.8",
    "happy-dom": "^20.7.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.0.18"
  }
}
